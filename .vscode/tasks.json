{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "setup-environment",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts\\setup-environment.ps1",
        "-AutoDetect",
        "-UpdateConfig"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "build-msipc-csharp-debug64",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts\\build.ps1",
        "-Configuration",
        "Debug64",
        "-Project",
        "Msipc.CSharp.WinForms"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": ["$msCompile"]
