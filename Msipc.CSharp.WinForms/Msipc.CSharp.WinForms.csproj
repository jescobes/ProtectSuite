<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!-- Deshabilitar NuGet ANTES de importar cualquier cosa -->
  <PropertyGroup>
    <SkipNuGetRestore>true</SkipNuGetRestore>
    <SkipRestorePackages>true</SkipRestorePackages>
    <RestorePackages>false</RestorePackages>
    <RestoreProjectStyle>None</RestoreProjectStyle>
    <IsRestoringPackage>false</IsRestoringPackage>
    <EnableNuGetRestore>false</EnableNuGetRestore>
    <!-- Evitar que MSBuild valide RuntimeIdentifier -->
    <ValidateNuGetPackageReferences>false</ValidateNuGetPackageReferences>
    <SkipValidateNuGetPackageReferences>true</SkipValidateNuGetPackageReferences>
  </PropertyGroup>
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{12345678-1234-1234-1234-123456789012}</ProjectGuid>
    <OutputType>WinExe</OutputType>
    <RootNamespace>Msipc.CSharp.WinForms</RootNamespace>
    <AssemblyName>Msipc.CSharp.WinForms</AssemblyName>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
    <Deterministic>true</Deterministic>
    <RestorePackages>false</RestorePackages>
    <DisableImplicitNuGetFallbackFolder>true</DisableImplicitNuGetFallbackFolder>
    <RuntimeIdentifier>win</RuntimeIdentifier>
    <RuntimeIdentifiers>win;win-x64;win-x86</RuntimeIdentifiers>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Drawing" />
    <Reference Include="System.Windows.Forms" />
    <Reference Include="System.Xml.Linq" />
    <Reference Include="System.Data.DataSetExtensions" />
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="System.Data" />
    <Reference Include="System.Net.Http" />
    <Reference Include="System.Xml" />
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
    <Reference Include="WindowsBase" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="MainForm.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Include="Program.cs" />
    <Compile Include="TemplatePickerDialog.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Include="UserRightsEditorDialog.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Include="SafeNativeMethods.cs" />
    <Compile Include="UnsafeNativeMethods.cs" />
    <Compile Include="SafeFileApiNativeMethods.cs" />
    <Compile Include="UnsafeFileApiNativeMethods.cs" />
    <Compile Include="ManagedAPIClasses.cs" />
    <Compile Include="NativeAPIStructures.cs" />
    <Compile Include="ILockBytesOverStream.cs" />
  </ItemGroup>
  <ItemGroup>
    <None Include="App.config" />
    <Content Include="..\config\adrms.json">
      <Link>config\adrms.json</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <!-- Referencias directas a DLLs sin usar NuGet packages.config -->
    <Reference Include="Microsoft.Identity.Client">
      <HintPath>bin\Debug\net472\Microsoft.Identity.Client.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="Newtonsoft.Json">
      <HintPath>bin\Debug\net472\Newtonsoft.Json.dll</HintPath>
      <Private>True</Private>
    </Reference>
  </ItemGroup>
  <!-- Deshabilitar completamente los targets de NuGet -->
  <PropertyGroup>
    <IsRestoringPackage>false</IsRestoringPackage>
    <RestorePackages>false</RestorePackages>
    <SkipRestorePackages>true</SkipRestorePackages>
  </PropertyGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
</Project>